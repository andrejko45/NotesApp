# These enviroment variables are used by Docker and Spring
# They wont be included in the github repo
# They are used to replace hardcoding sensitive data

# Database name
SPRING_DATASOURCE_DBNAME=notes_db

# Password
SPRING_DATASOURCE_PASSWORD=secret

# Root password
SPRING_DATASOURCE_ROOT_PASSWD=verysecret

# User name
SPRING_USER=avarszegi